<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Venue | 第2回同窓会</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Noto+Serif+JP:wght@400;500;600;700&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary:#12121a;--bg-secondary:#1a1a25;--bg-card:#1e1e2a;
      --bg-overlay:rgba(18,18,26,0.97);--text-primary:#eae7e0;--text-secondary:#a09b92;
      --text-muted:#6b6760;--accent-gold:#c9a84c;--accent-gold-light:#dfc06a;
      --accent-coral:#d25a32;--accent-teal:#32b48c;
      --border-subtle:rgba(201,168,76,0.15);--border-card:rgba(201,168,76,0.06);
      --font-display:'Cormorant Garamond','Noto Serif JP',serif;
      --font-body:'Noto Sans JP',sans-serif;--font-serif:'Noto Serif JP',serif;
      --space-xs:0.5rem;--space-sm:1rem;--space-md:2rem;--space-lg:4rem;--space-xl:6rem;
      --container-max:960px;--header-height:64px;
      --ease-out-expo:cubic-bezier(0.16,1,0.3,1);--ease-out-quart:cubic-bezier(0.25,1,0.5,1);
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}
    body{font-family:var(--font-body);font-weight:300;color:var(--text-primary);background:var(--bg-primary);background-image:radial-gradient(ellipse 80% 60% at 30% 20%,rgba(201,168,76,0.04) 0%,transparent 60%),radial-gradient(ellipse 60% 80% at 80% 70%,rgba(140,90,200,0.02) 0%,transparent 60%);background-attachment:fixed;line-height:1.8;letter-spacing:.02em;overflow-x:hidden;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}img{max-width:100%;height:auto;display:block;border-radius:6px}
    .container{width:100%;max-width:var(--container-max);margin:0 auto;padding:0 var(--space-md)}

    .site-header{position:fixed;top:0;left:0;right:0;z-index:1000;height:var(--header-height);background:rgba(18,18,26,0.6);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border-subtle)}
    .header-inner{max-width:var(--container-max);margin:0 auto;padding:0 var(--space-md);height:100%;display:flex;align-items:center;justify-content:space-between}
    .header-logo{display:flex;flex-direction:column;line-height:1.2}.logo-sub{font-size:.6rem;letter-spacing:.15em;color:var(--accent-gold)}.logo-main{font-family:var(--font-serif);font-size:1rem;font-weight:600;letter-spacing:.08em}
    .hamburger{position:relative;z-index:1100;width:32px;height:24px;background:none;border:none;cursor:pointer;display:flex;flex-direction:column;justify-content:space-between;padding:0}.hamburger-line{display:block;width:100%;height:1.5px;background:var(--text-primary);transition:all .4s var(--ease-out-expo);transform-origin:center}.hamburger.is-active .hamburger-line:nth-child(1){transform:translateY(11.25px) rotate(45deg)}.hamburger.is-active .hamburger-line:nth-child(2){opacity:0;transform:scaleX(0)}.hamburger.is-active .hamburger-line:nth-child(3){transform:translateY(-11.25px) rotate(-45deg)}
    .nav-overlay{position:fixed;inset:0;z-index:1050;background:var(--bg-overlay);opacity:0;visibility:hidden;transition:opacity .5s var(--ease-out-expo),visibility .5s;overflow-y:auto}.nav-overlay.is-open{opacity:1;visibility:visible}
    .nav-overlay-inner{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:calc(var(--header-height) + var(--space-lg)) var(--space-md) var(--space-lg);max-width:480px;margin:0 auto}
    .nav-section{padding:var(--space-sm) 0;border-bottom:1px solid var(--border-subtle)}.nav-section:last-of-type{border-bottom:none}
    .nav-label{display:block;font-family:var(--font-serif);font-size:.75rem;font-weight:500;color:var(--accent-gold);letter-spacing:.12em;padding-bottom:var(--space-xs);margin-bottom:var(--space-xs)}
    .nav-link{display:block;font-family:var(--font-display);font-size:1.5rem;color:var(--text-primary);padding:.4rem 0;transition:color .3s ease,transform .3s var(--ease-out-expo)}.nav-link:hover{color:var(--accent-gold);transform:translateX(8px)}.nav-link--active{color:var(--accent-gold)}
    .nav-link--sub{font-size:1.1rem;color:var(--text-secondary);padding-left:1.2rem;position:relative}.nav-link--sub::before{content:'';position:absolute;left:0;top:50%;width:12px;height:1px;background:var(--border-subtle)}.nav-link--sub:hover{color:var(--accent-gold-light)}
    .nav-footer{margin-top:var(--space-lg);padding-top:var(--space-md);border-top:1px solid var(--border-subtle)}.nav-contact{font-size:.85rem;color:var(--accent-gold);letter-spacing:.08em}

    .page-hero{position:relative;padding-top:calc(var(--header-height) + var(--space-xl));padding-bottom:var(--space-xl);overflow:hidden}
    .page-hero-bg{position:absolute;inset:0;background-image:url('images/venue.png');background-size:cover;background-position:center}
    .page-hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(18,18,26,.5) 0%,rgba(18,18,26,.9) 100%)}
    .page-hero-content{position:relative;z-index:1;text-align:center}
    .page-hero-title{font-family:var(--font-display);font-size:clamp(2rem,6vw,3rem);font-weight:700;color:var(--text-primary);letter-spacing:.1em;margin-bottom:var(--space-xs)}
    .page-hero-sub{font-family:var(--font-serif);font-size:clamp(.85rem,2vw,1rem);color:var(--text-secondary);letter-spacing:.08em}

    .section{padding:var(--space-xl) 0}
    .section-label{font-family:var(--font-display);font-size:.7rem;font-weight:600;letter-spacing:.25em;color:var(--accent-gold);text-transform:uppercase;margin-bottom:var(--space-xs)}
    .section-title{font-family:var(--font-serif);font-size:clamp(1.3rem,3.5vw,1.8rem);font-weight:600;color:var(--text-primary);letter-spacing:.05em;margin-bottom:var(--space-md)}

    /* Info cards - no emoji */
    .info-cards{display:flex;flex-direction:column;gap:var(--space-sm)}
    .info-card{background:var(--bg-card);border:1px solid var(--border-card);border-radius:10px;padding:1.3rem 1.4rem;transition:border-color .3s}
    .info-card:hover{border-color:var(--border-subtle)}
    .info-card-title{font-family:var(--font-serif);font-size:1rem;font-weight:600;color:var(--text-primary);margin-bottom:.4rem}
    .info-card-body{font-size:.82rem;color:var(--text-secondary);line-height:1.75}
    .info-card-body p{margin-bottom:.3rem}

    .info-card--warn{border-left:3px solid var(--accent-coral);border-radius:0 10px 10px 0;background:linear-gradient(135deg,rgba(210,90,50,.04),var(--bg-card) 60%)}
    .info-card--warn .info-card-title{color:var(--accent-coral)}
    .info-card--note{border-left:3px solid var(--accent-gold);border-radius:0 10px 10px 0;background:linear-gradient(135deg,rgba(201,168,76,.04),var(--bg-card) 60%)}
    .info-card--teal{border-left:3px solid var(--accent-teal);border-radius:0 10px 10px 0;background:linear-gradient(135deg,rgba(50,180,140,.04),var(--bg-card) 60%)}

    /* Venue grid */
    .venue-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--space-sm);margin-bottom:var(--space-md)}
    .venue-box{background:var(--bg-card);border:1px solid var(--border-card);border-radius:10px;padding:1.2rem;text-align:center;transition:border-color .3s}
    .venue-box:hover{border-color:var(--border-subtle)}
    .venue-box-label{font-family:var(--font-display);font-size:.65rem;font-weight:600;letter-spacing:.2em;color:var(--accent-gold);text-transform:uppercase;margin-bottom:.4rem}
    .venue-box-value{font-family:var(--font-serif);font-size:1rem;font-weight:600;color:var(--text-primary);margin-bottom:.2rem}
    .venue-box-detail{font-size:.75rem;color:var(--text-secondary);line-height:1.5}

    .afterparty-section{border-top:1px solid var(--border-subtle);padding-top:var(--space-xl)}

    .site-footer{padding:var(--space-md) 0;border-top:1px solid var(--border-subtle);text-align:center}
    .footer-contact{display:inline-block;font-size:.8rem;color:var(--accent-gold);letter-spacing:.1em;border:1px solid var(--border-subtle);padding:.5rem 1.5rem;transition:all .3s}.footer-contact:hover{border-color:var(--accent-gold)}
    .fade-in{opacity:0;transform:translateY(24px);transition:opacity .8s var(--ease-out-quart),transform .8s var(--ease-out-quart)}.fade-in.is-visible{opacity:1;transform:translateY(0)}
    @media(max-width:768px){:root{--header-height:56px}.venue-grid{grid-template-columns:1fr}.nav-link{font-size:1.3rem}.nav-link--sub{font-size:1rem}}
    @media(max-width:480px){.container{padding:0 var(--space-sm)}.info-card{padding:1rem}.venue-box{padding:1rem}}
    body.nav-open{overflow:hidden}
  </style>
</head>
<body>
  <header class="site-header" id="siteHeader"><div class="header-inner">
    <a href="index.html" class="header-logo"><span class="logo-sub">農大一中一高</span><span class="logo-main">第2回同窓会</span></a>
    <button class="hamburger" id="hamburger" aria-label="メニュー"><span class="hamburger-line"></span><span class="hamburger-line"></span><span class="hamburger-line"></span></button>
  </div></header>

  <nav class="nav-overlay" id="navOverlay" aria-hidden="true"><div class="nav-overlay-inner">
    <div class="nav-section"><a href="index.html" class="nav-link">ホーム</a></div>
    <div class="nav-section"><a href="schedule.html" class="nav-link">Schedule</a></div>
    <div class="nav-section"><span class="nav-label">長田頭取の野望</span><a href="nagata-about.html" class="nav-link nav-link--sub">ゲーム概要</a><a href="https://script.google.com/macros/s/AKfycbw-4tpXD_Yo1F84Mic6r4Fgl0LugDLakLE9ZD6TGp5JXhSXUFFI2FsfcxO5L-hO_05Otw/exec" target="_blank" class="nav-link nav-link--sub">ゲーム画面</a></div>
    <div class="nav-section"><a href="food.html" class="nav-link">Food &amp; 懇親会</a></div>
    <div class="nav-section"><a href="venue.html" class="nav-link nav-link--active">Venue</a></div>
    <div class="nav-section"><a href="qa.html" class="nav-link">Q&amp;A</a></div>
    <div class="nav-footer"><a href="https://docs.google.com/forms/d/e/1FAIpQLScaZqsb8PmDiATXvJReIDPr34LZl4RQOk-msbUmN5az5Q-R_g/viewform" target="_blank" rel="noopener" class="nav-contact">お問い合わせ</a></div>
  </div></nav>

  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero-bg"></div><div class="page-hero-overlay"></div>
    <div class="page-hero-content"><div class="container">
      <h1 class="page-hero-title">Venue</h1>
      <p class="page-hero-sub">会場案内・当日の準備</p>
    </div></div>
  </section>

  <!-- 当日の準備 -->
  <section class="section fade-in"><div class="container">
    <p class="section-label">Preparation</p>
    <h2 class="section-title">当日の準備</h2>

    <div class="info-cards">

      <div class="info-card info-card--note">
        <h3 class="info-card-title">入場について</h3>
        <div class="info-card-body">
          <p><strong style="color:var(--text-primary)">正門</strong>からご入場ください。守衛さんに「同窓会に参加します」とお伝えいただければ入場できます。</p>
          <p style="color:var(--accent-coral);margin-top:.3rem">※ 通用門からの入場はできません。桜新町方面からお越しの皆さん、すみません…！</p>
        </div>
      </div>

      <div class="info-card info-card--warn">
        <h3 class="info-card-title">交通手段について</h3>
        <div class="info-card-body">
          <p>懇親会ではお酒を提供するため、<strong style="color:var(--accent-coral)">自転車での来場はできません</strong>。学内に駐輪することもできませんので、ご了承ください。</p>
          <p>公共交通機関をご利用ください。</p>
        </div>
      </div>

      <div class="info-card">
        <h3 class="info-card-title">服装</h3>
        <div class="info-card-body">
          <p>カジュアルな格好で問題ありません。お気軽にお越しください。</p>
        </div>
      </div>

      <div class="info-card info-card--teal">
        <h3 class="info-card-title">前半の飲み物について</h3>
        <div class="info-card-body">
          <p>前半のレクリエーション中は飲み物の提供がありません。学内の自動販売機をご利用いただくか、事前にご自身で飲み物をご用意ください。</p>
        </div>
      </div>

    </div>
  </div></section>

  <!-- 2次会（会場の前に移動） -->
  <section class="section afterparty-section fade-in"><div class="container">
    <p class="section-label">After Party</p>
    <h2 class="section-title">2次会について</h2>

    <div class="info-cards">
      <div class="info-card info-card--note">
        <h3 class="info-card-title">2次会に参加される方へ</h3>
        <div class="info-card-body">
          <p>同窓会終了後、2次会の開催を予定しています。当日参加を希望される方は、運営メンバーにお声掛けください。</p>
          <p style="margin-top:.4rem"><strong style="color:var(--accent-gold)">2次会の会費は現金でのお支払い</strong>となります。事前にご準備のうえ、受付にてお支払いください。</p>
        </div>
      </div>
    </div>
  </div></section>

  <!-- 会場情報 -->
  <section class="section fade-in"><div class="container">
    <p class="section-label">Venue</p>
    <h2 class="section-title">会場</h2>

    <div class="venue-grid">
      <div class="venue-box">
        <p class="venue-box-label">前半</p>
        <p class="venue-box-value">3号館4階 大講義室</p>
        <p class="venue-box-detail">受付・開会式・長田頭取の野望</p>
      </div>
      <div class="venue-box">
        <p class="venue-box-label">後半</p>
        <p class="venue-box-value">国際センター1F レストラン</p>
        <p class="venue-box-detail">懇親会（立食形式）</p>
      </div>
    </div>
  </div></section>

  <footer class="site-footer"><div class="container">
    <a href="https://docs.google.com/forms/d/e/1FAIpQLScaZqsb8PmDiATXvJReIDPr34LZl4RQOk-msbUmN5az5Q-R_g/viewform" target="_blank" rel="noopener" class="footer-contact">お問い合わせ</a>
  </div></footer>

  <script>
    var h=document.getElementById('hamburger'),n=document.getElementById('navOverlay');h.addEventListener('click',function(){var o=h.classList.toggle('is-active');n.classList.toggle('is-open',o);n.setAttribute('aria-hidden',!o);h.setAttribute('aria-expanded',o);document.body.classList.toggle('nav-open',o)});n.querySelectorAll('a').forEach(function(l){l.addEventListener('click',function(){h.classList.remove('is-active');n.classList.remove('is-open');n.setAttribute('aria-hidden','true');h.setAttribute('aria-expanded','false');document.body.classList.remove('nav-open')})});document.addEventListener('keydown',function(e){if(e.key==='Escape'&&n.classList.contains('is-open'))h.click()});
    var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');obs.unobserve(e.target)}})},{rootMargin:'0px 0px -60px 0px',threshold:.1});document.querySelectorAll('.fade-in').forEach(function(el){obs.observe(el)});
    window.addEventListener('scroll',function(){document.getElementById('siteHeader').style.background=window.scrollY>80?'rgba(18,18,26,.92)':'rgba(18,18,26,.6)'},{passive:true});
  </script>
</body>
</html>
